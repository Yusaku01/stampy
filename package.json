{
  "name": "stampy-workspace",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yusaku01/stampy.git"
  },
  "bugs": {
    "url": "https://github.com/Yusaku01/stampy/issues"
  },
  "homepage": "https://github.com/Yusaku01/stampy#readme",
  "scripts": {
    "dev": "pnpm --filter @stampy/studio dev",
    "build": "pnpm -r build",
    "check": "pnpm -r check",
    "test": "pnpm -r test",
    "pack:core": "pnpm --filter @stampy/core pack --pack-destination ./tmp",
    "verify:core-consumer": "node scripts/verify-core-consumer.mjs",
    "release:core:check": "pnpm test && pnpm check && pnpm build && rm -rf tmp && mkdir -p tmp && pnpm pack:core && pnpm verify:core-consumer"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  },
  "packageManager": "pnpm@11.7.0"
}
