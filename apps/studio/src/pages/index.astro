---
import { ClientRouter } from "astro:transitions";

const customAnimatorExample = `await pressStamp(stamp, {
  preset: "classic",
  animator: async (element, context) => {
    element.animate(
      [
        { transform: "scale(1.6) translateY(-32px)", opacity: 0 },
        { transform: "scale(1)", opacity: 1 }
      ],
      { duration: context.durationMs, easing: "cubic-bezier(.2,.8,.2,1)" }
    );
  }
});`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Stampy Studio</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <ClientRouter />
    <link rel="stylesheet" href="/src/styles/studio.css" />
  </head>
  <body data-theme="light">
    <header class="studio-header">
      <div>
        <p class="eyebrow">Stampy Studio</p>
        <h1 data-i18n="heroTitle">Design stamps and press animations</h1>
      </div>
      <div class="header-actions">
        <label class="compact-control" for="project-name">
          <span data-i18n="projectName">Project</span>
          <input
            id="project-name"
            name="projectName"
            value="Onsen visit stamp"
            maxlength="48"
            autocomplete="off"
            data-project-name
          />
        </label>
        <label class="compact-control" for="locale">
          <span data-i18n="language">Language</span>
          <select id="locale" name="locale" data-locale-select aria-label="Language">
            <option value="en">English</option>
            <option value="ja">日本語</option>
          </select>
        </label>
        <label class="compact-control" for="theme">
          <span data-i18n="theme">Theme</span>
          <select id="theme" name="theme" data-theme-select aria-label="Theme">
            <option value="auto">Auto</option>
            <option value="light">Light</option>
            <option value="dark">Dark</option>
          </select>
        </label>
        <button type="button" class="ghost-button" data-action="copy-html">
          <span data-i18n="copyEmbed">Copy embed</span>
        </button>
        <button type="button" class="ghost-button" data-action="copy-json">
          <span data-i18n="copyJson">Copy JSON</span>
        </button>
        <button type="button" class="ghost-button" data-action="export-json">
          <span data-i18n="exportJson">Export JSON</span>
        </button>
        <label class="file-button" for="project-import">
          <span data-i18n="importJson">Import JSON</span>
          <input
            id="project-import"
            type="file"
            accept="application/json,.json"
            data-project-import
          />
        </label>
        <button type="button" class="primary-button" data-action="export-svg">
          <span data-i18n="exportSvg">Export SVG</span>
        </button>
      </div>
    </header>

    <main class="studio-shell">
      <section class="tool-panel" aria-labelledby="stamp-controls-title">
        <h2 id="stamp-controls-title" data-i18n="stamp">Stamp</h2>
        <form class="control-grid" data-stampy-form>
          <label for="main-text">
            <span data-i18n="mainText">Main text</span>
            <input
              id="main-text"
              name="mainText"
              value="Visited"
              maxlength="16"
              autocomplete="off"
            />
          </label>
          <label for="sub-text">
            <span data-i18n="subText">Sub text</span>
            <input
              id="sub-text"
              name="subText"
              value="Stampy"
              maxlength="18"
              autocomplete="off"
            />
          </label>
          <label for="date-text">
            <span data-i18n="date">Date</span>
            <input
              id="date-text"
              name="dateText"
              value="2026.06.27"
              maxlength="12"
              autocomplete="off"
            />
          </label>
          <label for="shape">
            <span data-i18n="shape">Shape</span>
            <select id="shape" name="shape">
              <option value="circle" data-i18n="circle">Circle</option>
              <option value="ticket" data-i18n="ticket">Ticket</option>
              <option value="rounded" data-i18n="rounded">Rounded</option>
            </select>
          </label>
          <label for="icon">
            <span data-i18n="icon">Icon</span>
            <select id="icon" name="icon">
              <option value="steam" data-i18n="steam">Steam</option>
              <option value="star" data-i18n="star">Star</option>
              <option value="spark" data-i18n="spark">Spark</option>
              <option value="none" data-i18n="none">None</option>
            </select>
          </label>
          <label for="ink">
            <span data-i18n="ink">Ink</span>
            <input id="ink" name="ink" type="color" value="#b93632" />
          </label>
          <label for="paper">
            <span data-i18n="paper">Paper</span>
            <input id="paper" name="paper" type="color" value="#fffaf4" />
          </label>
          <label class="range-control" for="distress">
            <span class="range-head">
              <span data-i18n="distress">Distress</span>
              <output for="distress" data-range-output="distress">0.72</output>
            </span>
            <input
              id="distress"
              name="distress"
              type="range"
              min="0"
              max="1"
              step="0.05"
              value="0.72"
            />
          </label>
          <label class="range-control" for="roughen">
            <span class="range-head">
              <span data-i18n="roughen">Roughen</span>
              <output for="roughen" data-range-output="roughen">2.25</output>
            </span>
            <input
              id="roughen"
              name="roughen"
              type="range"
              min="0"
              max="8"
              step="0.25"
              value="2.25"
            />
          </label>
          <label class="range-control" for="rotate">
            <span class="range-head">
              <span data-i18n="rotate">Rotate</span>
              <output for="rotate" data-range-output="rotate">-6deg</output>
            </span>
            <input
              id="rotate"
              name="rotate"
              type="range"
              min="-24"
              max="24"
              step="1"
              value="-6"
            />
          </label>
        </form>
      </section>

      <section class="preview-panel" aria-labelledby="preview-title">
        <div class="preview-toolbar">
          <div>
            <h2 id="preview-title" data-i18n="preview">Preview</h2>
            <p data-status data-i18n="ready" aria-live="polite" aria-atomic="true">Ready</p>
          </div>
          <div class="preview-actions">
            <button type="button" class="ghost-button" data-action="press">
              <span data-i18n="press">Press</span>
            </button>
            <button type="button" class="ghost-button" data-action="export-png">
              PNG
            </button>
          </div>
        </div>

        <div class="preview-stage">
          <stampy-mark
            id="studio-stamp"
            main-text="Visited"
            sub-text="Stampy"
            date-text="2026.06.27"
            ink="#b93632"
            paper="#fffaf4"
          ></stampy-mark>
        </div>
      </section>

      <section class="tool-panel" aria-labelledby="animation-title">
        <h2 id="animation-title" data-i18n="animation">Animation</h2>
        <form class="control-grid" data-animation-form>
          <label for="preset">
            <span data-i18n="preset">Preset</span>
            <select id="preset" name="preset">
              <option value="classic" data-i18n="classicPress">Classic press</option>
              <option value="bounce" data-i18n="bounce">Bounce</option>
              <option value="ink" data-i18n="inkReveal">Ink reveal</option>
              <option value="none" data-i18n="none">None</option>
            </select>
          </label>
          <label class="range-control" for="duration-ms">
            <span class="range-head">
              <span data-i18n="duration">Duration</span>
              <output for="duration-ms" data-range-output="durationMs">780ms</output>
            </span>
            <input
              id="duration-ms"
              name="durationMs"
              type="range"
              min="120"
              max="1600"
              step="20"
              value="780"
            />
          </label>
          <label class="range-control" for="intensity">
            <span class="range-head">
              <span data-i18n="intensity">Intensity</span>
              <output for="intensity" data-range-output="intensity">1.0x</output>
            </span>
            <input
              id="intensity"
              name="intensity"
              type="range"
              min="0.4"
              max="1.8"
              step="0.1"
              value="1"
            />
          </label>
        </form>
        <details>
          <summary data-i18n="customAnimatorApi">Custom animator API</summary>
          <pre tabindex="0"><code>{customAnimatorExample}</code></pre>
        </details>
      </section>

      <section class="code-panel" aria-labelledby="code-title">
        <h2 id="code-title" data-i18n="embed">Embed</h2>
        <pre tabindex="0"><code data-embed-code></code></pre>
      </section>

      <section class="code-panel project-panel" aria-labelledby="project-title">
        <h2 id="project-title" data-i18n="projectData">Project data</h2>
        <pre tabindex="0"><code data-project-code></code></pre>
      </section>
    </main>

    <script src="../scripts/studio.ts"></script>
  </body>
</html>
