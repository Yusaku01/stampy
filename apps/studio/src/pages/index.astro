---
import { ClientRouter } from "astro:transitions";

const iconAttrs = {
  "aria-hidden": "true",
  class: "button-icon",
  fill: "none",
  height: "16",
  stroke: "currentColor",
  "stroke-linecap": "round",
  "stroke-linejoin": "round",
  "stroke-width": "2",
  viewBox: "0 0 24 24",
  width: "16",
} as const;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Stampy Studio</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <ClientRouter />
    <link rel="stylesheet" href="/src/styles/studio.css" />
  </head>
  <body data-theme="light">
    <header class="studio-header">
      <div>
        <h1 class="studio-title">Stampy Studio</h1>
      </div>
      <div class="header-actions">
        <fieldset class="compact-control segmented-control" aria-label="Language">
          <div class="segment-options" role="group" aria-label="Language">
            <button type="button" aria-pressed="true" data-locale-option="en">
              English
            </button>
            <button type="button" aria-pressed="false" data-locale-option="ja">
              日本語
            </button>
          </div>
        </fieldset>
        <div class="theme-menu">
          <button
            type="button"
            class="theme-menu-toggle"
            aria-haspopup="menu"
            aria-expanded="false"
            aria-controls="theme-options"
            data-theme-toggle
          >
            <span data-theme-label data-i18n="auto">Auto</span>
            <span aria-hidden="true">⌄</span>
          </button>
          <div id="theme-options" class="menu-options theme-options" role="menu" hidden>
            <button type="button" role="menuitemradio" aria-checked="true" data-theme-option="auto">
              <span data-i18n="auto">Auto</span>
            </button>
            <button type="button" role="menuitemradio" aria-checked="false" data-theme-option="light">
              <span data-i18n="light">Light</span>
            </button>
            <button type="button" role="menuitemradio" aria-checked="false" data-theme-option="dark">
              <span data-i18n="dark">Dark</span>
            </button>
          </div>
        </div>
      </div>
    </header>

    <main class="studio-shell">
      <section class="tool-panel" aria-labelledby="stamp-controls-title">
        <h2 id="stamp-controls-title" data-i18n="stamp">Stamp</h2>
        <form class="control-grid" data-stampy-form>
          <label for="main-text">
            <span data-i18n="mainText">Main text</span>
            <input
              id="main-text"
              name="mainText"
              value="Visited"
              maxlength="16"
              autocomplete="off"
            />
          </label>
          <label for="sub-text">
            <span data-i18n="subText">Sub text</span>
            <input
              id="sub-text"
              name="subText"
              value="Stampy"
              maxlength="18"
              autocomplete="off"
            />
          </label>
          <label for="date-text">
            <span data-i18n="date">Date</span>
            <input
              id="date-text"
              name="dateText"
              value="2026.06.27"
              maxlength="12"
              autocomplete="off"
            />
          </label>
          <label for="shape">
            <span data-i18n="shape">Shape</span>
            <select id="shape" name="shape">
              <option value="circle" data-i18n="circle">Circle</option>
              <option value="square" data-i18n="square">Square</option>
              <option value="triangle" data-i18n="triangle">Triangle</option>
              <option value="star" data-i18n="starShape">Star</option>
              <option value="ticket" data-i18n="ticket">Ticket</option>
            </select>
          </label>
          <label class="range-control" for="corner-radius">
            <span class="range-head">
              <span data-i18n="cornerRadius">Corner radius</span>
              <span class="range-value-field">
                <input
                  type="number"
                  min="0"
                  max="32"
                  step="1"
                  value="0"
                  aria-label="Corner radius value"
                  data-range-number="cornerRadius"
                />
                <span>px</span>
              </span>
            </span>
            <input
              id="corner-radius"
              name="cornerRadius"
              type="range"
              min="0"
              max="32"
              step="1"
              value="0"
            />
          </label>
          <label for="icon">
            <span data-i18n="icon">Icon</span>
            <select id="icon" name="icon">
              <option value="steam" data-i18n="steam">Steam</option>
              <option value="star" data-i18n="star">Star</option>
              <option value="spark" data-i18n="spark">Spark</option>
              <option value="none" data-i18n="none">None</option>
            </select>
          </label>
          <label for="ink">
            <span data-i18n="ink">Background color</span>
            <input id="ink" name="ink" type="color" value="#b93632" />
          </label>
          <label class="range-control" for="ink-opacity">
            <span class="range-head">
              <span data-i18n="inkOpacity">Opacity</span>
              <span class="range-value-field">
                <input
                  type="number"
                  min="0"
                  max="100"
                  step="5"
                  value="100"
                  aria-label="Opacity value"
                  data-range-number="inkOpacity"
                />
                <span>%</span>
              </span>
            </span>
            <input
              id="ink-opacity"
              name="inkOpacity"
              type="range"
              min="0"
              max="1"
              step="0.05"
              value="1"
            />
          </label>
          <label for="paper">
            <span data-i18n="paper">Text color</span>
            <input id="paper" name="paper" type="color" value="#fffaf4" />
          </label>
          <label class="range-control" for="distress">
            <span class="range-head">
              <span data-i18n="distress">Distress</span>
              <span class="range-value-field">
                <input
                  type="number"
                  min="0"
                  max="1"
                  step="0.05"
                  value="0.72"
                  aria-label="Distress value"
                  data-range-number="distress"
                />
              </span>
            </span>
            <input
              id="distress"
              name="distress"
              type="range"
              min="0"
              max="1"
              step="0.05"
              value="0.72"
            />
          </label>
          <label class="range-control" for="roughen">
            <span class="range-head">
              <span data-i18n="roughen">Roughen</span>
              <span class="range-value-field">
                <input
                  type="number"
                  min="0"
                  max="8"
                  step="0.25"
                  value="2.25"
                  aria-label="Roughen value"
                  data-range-number="roughen"
                />
              </span>
            </span>
            <input
              id="roughen"
              name="roughen"
              type="range"
              min="0"
              max="8"
              step="0.25"
              value="2.25"
            />
          </label>
          <label class="range-control" for="rotate">
            <span class="range-head">
              <span data-i18n="rotate">Rotate</span>
              <span class="range-value-field">
                <input
                  type="number"
                  min="-360"
                  max="360"
                  step="1"
                  value="-6"
                  aria-label="Rotate value"
                  data-range-number="rotate"
                />
                <span>deg</span>
              </span>
            </span>
            <input
              id="rotate"
              name="rotate"
              type="range"
              min="-360"
              max="360"
              step="1"
              value="-6"
            />
          </label>
        </form>
      </section>

      <section class="workspace-panel" aria-labelledby="workspace-title">
        <div class="workspace-toolbar">
          <div class="tab-list" role="tablist" aria-label="Workspace">
            <button
              type="button"
              id="preview-tab"
              class="tab-button"
              role="tab"
              aria-controls="preview-panel"
              aria-selected="true"
              data-view-tab="preview"
            >
              <svg {...iconAttrs}>
                <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
              <span data-i18n="preview">Preview</span>
            </button>
            <button
              type="button"
              id="code-tab"
              class="tab-button"
              role="tab"
              aria-controls="code-panel"
              aria-selected="false"
              data-view-tab="code"
            >
              <svg {...iconAttrs}>
                <path d="m10 16 4-8"></path>
                <path d="m6 8-4 4 4 4"></path>
                <path d="m18 8 4 4-4 4"></path>
              </svg>
              <span data-i18n="code">Code</span>
            </button>
          </div>
          <h2 id="workspace-title" class="visually-hidden">Workspace</h2>
          <div class="workspace-actions">
            <div class="preview-actions" data-view-actions="preview">
              <button type="button" class="ghost-button" data-action="press">
                <svg {...iconAttrs}>
                  <path d="M6 4v16l14-8-14-8z"></path>
                </svg>
                <span data-i18n="press">Play</span>
              </button>
              <div class="export-menu">
                <button
                  type="button"
                  class="primary-button"
                  aria-haspopup="menu"
                  aria-expanded="false"
                  aria-controls="export-options"
                  data-export-toggle
                >
                  <svg {...iconAttrs}>
                    <path d="M15 3h6v6"></path>
                    <path d="M10 14 21 3"></path>
                    <path d="M21 14v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5"></path>
                  </svg>
                  <span data-i18n="export">Export</span>
                </button>
                <div id="export-options" class="menu-options export-options" role="menu" hidden>
                  <button type="button" role="menuitem" data-action="export-png">
                    PNG
                  </button>
                  <button type="button" role="menuitem" data-action="export-svg">
                    SVG
                  </button>
                </div>
              </div>
            </div>
            <div class="preview-actions" data-view-actions="code" hidden>
              <button type="button" class="ghost-button" data-action="copy-html">
                <span data-copy-label data-i18n="copyEmbed">Copy embed</span>
              </button>
            </div>
          </div>
        </div>

        <div
          id="preview-panel"
          class="tab-panel preview-stage"
          role="tabpanel"
          aria-labelledby="preview-tab"
          data-view-panel="preview"
        >
          <stampy-mark
            id="studio-stamp"
            main-text="Visited"
            sub-text="Stampy"
            date-text="2026.06.27"
            ink="#b93632"
            ink-opacity="1"
            paper="#fffaf4"
            rotate="-6"
          ></stampy-mark>
        </div>
        <div
          id="code-panel"
          class="tab-panel code-stage"
          role="tabpanel"
          aria-labelledby="code-tab"
          data-view-panel="code"
          hidden
        >
          <pre tabindex="0"><code data-embed-code></code></pre>
        </div>
      </section>

      <section class="tool-panel" aria-labelledby="anime-sound-title">
        <h2 id="anime-sound-title" data-i18n="animeSound">Animation & Sound</h2>
        <form class="control-grid" data-animation-form>
          <label for="preset">
            <span data-i18n="preset">Preset</span>
            <select id="preset" name="preset">
              <option value="classic" data-i18n="classicPress">Classic press</option>
              <option value="bounce" data-i18n="bounce">Bounce</option>
              <option value="ink" data-i18n="inkReveal">Ink reveal</option>
              <option value="none" data-i18n="none">None</option>
            </select>
          </label>
          <label class="range-control" for="duration-ms" data-animation-detail>
            <span class="range-head">
              <span data-i18n="duration">Duration</span>
              <span class="range-value-field">
                <input
                  type="number"
                  min="120"
                  max="1600"
                  step="20"
                  value="780"
                  aria-label="Duration value"
                  data-range-number="durationMs"
                />
                <span>ms</span>
              </span>
            </span>
            <input
              id="duration-ms"
              name="durationMs"
              type="range"
              min="120"
              max="1600"
              step="20"
              value="780"
            />
          </label>
          <label class="range-control" for="intensity" data-animation-detail>
            <span class="range-head">
              <span data-i18n="intensity">Intensity</span>
              <span class="range-value-field">
                <input
                  type="number"
                  min="0.4"
                  max="1.8"
                  step="0.1"
                  value="1"
                  aria-label="Intensity value"
                  data-range-number="intensity"
                />
                <span>x</span>
              </span>
            </span>
            <input
              id="intensity"
              name="intensity"
              type="range"
              min="0.4"
              max="1.8"
              step="0.1"
              value="1"
            />
          </label>
        </form>
        <label class="sound-control" for="press-sound" hidden>
          <span data-i18n="pressSound">Press sound</span>
          <span class="sound-placeholder" data-i18n="noSound">None</span>
          <audio id="press-sound" preload="none" data-press-audio></audio>
        </label>
      </section>
    </main>

    <script src="../scripts/studio.ts"></script>
  </body>
</html>
